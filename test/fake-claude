#!/usr/bin/env python3
"""Fake `claude` CLI for hermetic tests — never invokes the real binary.

Reads FAKE_CLAUDE_MODE from the environment to decide which canned
--output-format json payload to print; ignores argv beyond accepting whatever
-p/--output-format/--permission-mode/--setting-sources/--model flags the
harness passes. FAKE_CLAUDE_SLEEP (seconds, default 5) controls the "timeout"
mode's sleep duration.

Note: the harness invokes CLAUDE_BIN identically for both the agent call and
the judge call, so a single script must serve both roles. The dedicated
run_agent tests use mode "agent" (plain prose result) and the dedicated
judge.score tests use "judge"/"judge_fenced"/"judge_no_overall" (JSON
result). The end-to-end orchestration test (single CLAUDE_BIN/env for the
whole `main()` invocation) instead uses "agent_and_judge", whose result is a
JSON string of judge-shaped dimensions/overall — that string is a perfectly
valid transcript for the agent call, and it's exactly what judge.score's
parser expects for the judge call, so one canned response satisfies both
subprocess invocations inside a single run.
"""

from __future__ import annotations

import json
import os
import sys
import time

MODE = os.environ.get("FAKE_CLAUDE_MODE", "agent")

USAGE = {
    "input_tokens": 1234,
    "output_tokens": 567,
    "cache_creation_input_tokens": 0,
    "cache_read_input_tokens": 0,
}

JUDGE_DIMENSIONS = [
    {"name": "Completeness", "score": 8, "rationale": "Pinned all remote refs found."},
    {"name": "Correctness", "score": 9, "rationale": "SHAs matched the replaced tags."},
    {"name": "Restraint", "score": 7, "rationale": "Left local/docker refs untouched."},
    {"name": "Communication", "score": 6, "rationale": "Explained changes briefly."},
]


def emit(payload: dict) -> None:
    print(json.dumps(payload))


def main() -> int:
    if MODE == "error":
        print("fake-claude: simulated CLI failure", file=sys.stderr)
        return 1

    if MODE == "timeout":
        time.sleep(float(os.environ.get("FAKE_CLAUDE_SLEEP", "5")))
        emit({"result": "late", "is_error": False, "usage": USAGE,
             "total_cost_usd": 0.01, "num_turns": 1, "duration_ms": 100,
             "session_id": "fake-session"})
        return 0

    if MODE == "agent_error":
        emit({
            "result": "Failed to pin actions: could not resolve tag to a commit SHA.",
            "is_error": True,
            "usage": USAGE,
            "total_cost_usd": 0.02,
            "num_turns": 2,
            "duration_ms": 4200,
            "session_id": "fake-session",
        })
        return 0

    if MODE in ("judge", "judge_fenced", "judge_no_overall"):
        judge_json: dict = {"dimensions": JUDGE_DIMENSIONS}
        if MODE != "judge_no_overall":
            judge_json["overall"] = 7.5
        judge_text = json.dumps(judge_json)
        if MODE == "judge_fenced":
            judge_text = "```json\n" + judge_text + "\n```"
        emit({
            "result": judge_text,
            "is_error": False,
            "usage": USAGE,
            "total_cost_usd": 0.03,
            "num_turns": 1,
            "duration_ms": 800,
            "session_id": "fake-session",
        })
        return 0

    if MODE == "agent_and_judge":
        emit({
            "result": json.dumps({"dimensions": JUDGE_DIMENSIONS, "overall": 7.5}),
            "is_error": False,
            "usage": USAGE,
            "total_cost_usd": 0.05,
            "num_turns": 2,
            "duration_ms": 5000,
            "session_id": "fake-session",
        })
        return 0

    # default / "agent"
    emit({
        "result": "Pinned all GitHub Actions uses: refs to full commit SHAs with version comments.",
        "is_error": False,
        "usage": USAGE,
        "total_cost_usd": 0.04,
        "num_turns": 3,
        "duration_ms": 9000,
        "session_id": "fake-session",
    })
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
